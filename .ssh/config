# github
# -------------------------
# for メインアカウント
Host github.com
  HostName github.com
  User git
  Port 22
  IdentityFile ~/.ssh/id_rsa
  TCPKeepAlive yes
  IdentitiesOnly yes

# for twアカウント
Host tw.github.com
  HostName github.com
  User git
  Port 22
  IdentityFile ~/.ssh/tw.id_rsa
  TCPKeepAlive yes
  IdentitiesOnly yes

